{
  "name": "fullstackopen-w",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run coc",
    "coc": "tsx --tsconfig ./jsconfig.json ./coc_boot.js",
    "preview.wp": "http-server ./wp-build",
    "dev-p": "run-p start start.be",
    "start": "bun --cwd ./frontend run dev",
    "start.be": "bun --cwd ./backend run dev",
    "server.person": "json-server -p3725 --watch ./backend/db-person.json",
    "ping.fe": "bun --cwd ./frontend run echo",
    "ping.be": "bun --cwd ./backend run echo",
    "lint": "eslint ./src",
    "cypress:open": "cypress open",
    "test.e2e": "cypress run"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.61.1",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/compat": "^2.0.5",
    "@types/node": "~25.6.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cypress": "^15.14.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "json-server": "^1.0.0-beta.15",
    "nolyfill": "^1.0.44",
    "npm-run-all2": "^8.0.4",
    "tree-kill": "^1.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "web-vitals": "3.5.2"
  },
  "workspaces": [
    "./frontend",
    "./backend"
  ],
  "packageManager": "bun@1.3.13",
  "dependencies": {
    "no-try": "^4.0.0",
    "postinstall-postinstall": "^2.1.0",
    "stale-dep": "^0.8.5"
  }
}
{
  "compilerOptions": {
    "composite": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "rootDir": "./frontend",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "frontend/src",
    "frontend/cra"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}
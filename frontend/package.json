{
  "name": "@fullstackopen-w/frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run start",
    "start": "cross-env PORT=3720 react-app-rewired start",
    "build": "cross-env PORT=3720 react-app-rewired build",
    "dev.wp": "webpack serve --mode development -c ./webpack.config.mjs",
    "build.wp": "webpack --mode development -c ./webpack.config.mjs",
    "preview.wp": "http-server ./wp-build",
    "test": "vitest run",
    "test.old": "cross-env NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\"  react-app-rewired test --setupFilesAfterEnv ./src/setupTests.js",
    "test.update": "vitest run --update",
    "eject": "react-scripts eject",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "coverage": "vitest run --coverage",
    "coverage.html": "http-server ./coverage -o"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.2",

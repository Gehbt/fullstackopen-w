{
  "compilerOptions": {
    "composite": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "alwaysStrict": true,
    "rootDir": "./backend",
    "paths": {
      "~/*": [
        "./*"
      ]
    },
    "outDir": "./build",
    "types": [
      "node"
    ]
  },
  "include": [
    "backend",
    "backend/*.json"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}
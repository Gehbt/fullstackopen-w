    "dev.be": "dotenvx run -q -f .env.local -- nodemon ./index.js",
    "echo": "tsx ./db/log.js",
    "test": "cross-env NODE_ENV=test jest --verbose",
    "test.note.api": "cross-env NODE_ENV=test jest --verbose tests/note_api.test.js",
    "test.blog.api": "cross-env NODE_ENV=test jest --verbose tests/blog_api.test.js",
    "test.note.api.spec": "cross-env NODE_ENV=test jest --verbose tests/note_api.test.js -t \"fails with statuscode 404 if note does not exist\"",
    "test.user.api": "cross-env NODE_ENV=test jest --verbose tests/user_api.test.js",
    "start:test": "cross-env NODE_ENV=test node index.js"
  },
